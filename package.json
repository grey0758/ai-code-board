{
  "name": "ai-code-board",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "server": "npm run start -w packages/server",
    "agent": "npm run start -w packages/agent",
    "build": "npm run build -w packages/shared && npm run build -w packages/server && npm run build -w packages/agent && npm run build -w packages/agent-win",
    "dev:server": "npm run dev -w packages/server",
    "dev:agent": "npm run dev -w packages/agent",
    "dev:web": "npm run dev -w packages/web"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0"
  }
}
